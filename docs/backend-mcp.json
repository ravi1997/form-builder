{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/ravi/workspace/docker/apps/form-backend",
        "/home/ravi/workspace/frontend"
      ]
    },
    "git-backend": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/home/ravi/workspace/docker/apps/form-backend"
      ]
    },
    "git-frontend": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/home/ravi/workspace/frontend"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@0.0.38"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time",
        "--local-timezone=Asia/Kolkata"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "/home/ravi/workspace/docker/apps/form-backend/.agents/memory.json"
      }
    },
    "github": {
      "command": "sh",
      "args": [
        "-lc",
        "set -a; . \"$HOME/.config/ridp-agent/github-mcp.env\"; exec docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN ghcr.io/github/github-mcp-server"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp"
      ]
    }
  }
}
