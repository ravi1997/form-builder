# Testing Environment Configuration
# This file contains testing-specific settings
# Copy to .env.test for automated testing

# Flask Configuration
FLASK_ENV=testing
DEBUG=false
SECRET_KEY=test-secret-key
JWT_SECRET_KEY=test-jwt-secret-key

# Database Configuration (in-memory or test containers)
MONGO_URI=mongomock://localhost
REDIS_URL=redis://localhost:6379/1  # Use different DB for testing
ELASTICSEARCH_URL=http://localhost:9200

# Email/SMS API (testing - mock endpoints)
EMAIL_API_URL=http://mock-api:8080/email
EMAIL_API_TOKEN=test-token
SMS_API_URL=http://mock-api:8080/sms
SMS_API_TOKEN=test-token

# File Upload Configuration (testing)
UPLOADS_ROOT=/tmp/test-uploads
MAX_UPLOAD_SIZE_PDF=1048576  # 1MB in tests
MAX_UPLOAD_SIZE_VIDEO=1048576  # 1MB in tests
MAX_UPLOAD_SIZE_IMAGE=1048576  # 1MB in tests
MAX_UPLOAD_SIZE_OTHER=1048576  # 1MB in tests

# Celery Configuration (testing - disable or use eager mode)
CELERY_TASK_ALWAYS_EAGER=true
CELERY_TASK_EAGER_PROPAGATES=true
CELERY_RESULT_BACKEND=cache
CELERY_CACHE_BACKEND=memory

# Plugin System Configuration (testing)
PLUGINS_ENABLED=true
PLUGINS_SANDBOX_ENABLED=false  # Disable sandboxing in tests
PLUGINS_SANDBOX_TIMEOUT=10
PLUGINS_MAX_MEMORY_MB=128

# Analysis Execution Configuration (testing)
ANALYSIS_MAX_RUNTIME_SECONDS=30  # Very short timeout in tests
ANALYSIS_MAX_NODES=10
ANALYSIS_CACHE_TTL_SECONDS=60  # Very short cache in tests

# Dashboard Canvas Configuration (testing)
DASHBOARD_MAX_WIDGETS=10
DASHBOARD_AUTO_REFRESH_ENABLED=false
DASHBOARD_DEFAULT_REFRESH_INTERVAL_SECONDS=1

# Form Versioning Configuration (testing)
FORM_VERSIONING_ENABLED=true
FORM_MAX_BRANCHES=5
FORM_MAX_COMMITS_PER_BRANCH=100

# Redis Configuration (testing)
REDIS_CACHE_DB=1  # Use different DB for testing
REDIS_SESSION_DB=2
REDIS_RATE_LIMIT_DB=3
REDIS_PRESENCE_DB=4
REDIS_CACHE_TTL_SECONDS=60

# Elasticsearch Configuration (testing)
ELASTICSEARCH_INDEX_PREFIX=formbuilder_test

# ClamAV Integration (testing - disabled)
CLAMAV_ENABLED=false

# CORS Configuration (testing)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting (testing - disabled)
RATE_LIMIT_ENABLED=false

# Platform Configuration
PLATFORM_VERSION=1.0.0-test
PLATFORM_NAME="Form Builder Platform (TEST)"
MAINTENANCE_MODE=false
REGISTRATION_OPEN=true

# Security Configuration (testing)
BCRYPT_ROUNDS=4  # Faster hashing in tests
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600  # 1 hour in tests
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=7200  # 2 hours in tests
PASSWORD_MIN_LENGTH=6

# Monitoring and Logging (testing)
LOG_LEVEL=WARNING
LOG_FORMAT=text
SENTRY_DSN=
METRICS_ENABLED=false
HEALTH_CHECK_ENABLED=false

# Storage Configuration (testing)
DEFAULT_STORAGE_QUOTA_BYTES=104857600  # 100MB in tests
STORAGE_WARNING_THRESHOLD=0.9
FILE_CLEANUP_ENABLED=false

# Notification Configuration (testing)
NOTIFICATION_MAX_RETRIES=0  # No retries in tests
WEBHOOK_MAX_RETRIES=0

# Tus Configuration (testing)
TUS_CHUNK_SIZE=1024  # 1KB chunks in tests
TUS_MAX_FILE_SIZE=1048576  # 1MB in tests

# WebSocket Configuration (testing)
SOCKETIO_ASYNC_MODE=threading

# Testing-specific settings
TESTING=true
TEST_DATABASE_URI=mongomock://localhost
TEST_REDIS_URL=redis://localhost:6379/1
TEST_UPLOADS_DIR=/tmp/test-uploads
TEST_CLEANUP_FILES=true